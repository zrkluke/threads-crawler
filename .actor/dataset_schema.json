{
    "$schema": "https://apify.com/schemas/v1/dataset.ide.json",
    "actorSpecification": 1,
    "fields": {},
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": ["mode", "target", "url", "profile", "posts", "media_urls", "scraped_at"]
            },
            "display": {
                "component": "table",
                "properties": {
                    "mode": {
                        "label": "Mode",
                        "format": "text"
                    },
                    "target": {
                        "label": "Target",
                        "format": "text"
                    },
                    "url": {
                        "label": "URL",
                        "format": "link"
                    },
                    "profile": {
                        "label": "Profile",
                        "format": "object"
                    },
                    "posts": {
                        "label": "Posts",
                        "format": "array"
                    },
                    "media_urls": {
                        "label": "Media URLs",
                        "format": "array"
                    },
                    "scraped_at": {
                        "label": "Scraped at",
                        "format": "date"
                    }
                }
            }
        }
    }
}
